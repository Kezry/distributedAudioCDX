<Window x:Class="Dacdx.Windows.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="distributedAudioCDX Sender"
        Width="1120"
        Height="680"
        MinWidth="860"
        MinHeight="520">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
      <Button Width="116" Height="34" Margin="0,0,8,0" Click="Scan_Click">Scan</Button>
      <Button Width="116" Height="34" Margin="0,0,8,0" Click="SendTone_Click">Test tone</Button>
      <Button x:Name="LoopbackButton" Width="136" Height="34" Margin="0,0,8,0" Click="Loopback_Click">Start loopback</Button>
      <ComboBox x:Name="LayoutCombo" Width="132" Height="34" Margin="0,0,8,0" SelectedIndex="0">
        <ComboBoxItem Content="2.0 Stereo" />
        <ComboBoxItem Content="2.1" />
        <ComboBoxItem Content="5.1" />
        <ComboBoxItem Content="7.1" />
      </ComboBox>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="Ready" />
    </StackPanel>

    <DataGrid x:Name="DeviceGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              HeadersVisibility="Column"
              ItemsSource="{Binding Devices}">
      <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="Use" Binding="{Binding Enabled}" Width="64" />
        <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="92" IsReadOnly="True" />
        <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="190" IsReadOnly="True" />
        <DataGridTextColumn Header="Alias" Binding="{Binding Alias}" Width="180" />
        <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="130" IsReadOnly="True" />
        <DataGridTextColumn Header="Mode" Binding="{Binding ActiveMode}" Width="120" IsReadOnly="True" />
        <DataGridComboBoxColumn x:Name="ChannelColumn"
                                Header="Channel"
                                SelectedItemBinding="{Binding AssignedChannel}"
                                Width="150" />
        <DataGridTextColumn Header="Latency ms" Binding="{Binding LatencyMs}" Width="100" IsReadOnly="True" />
        <DataGridTextColumn Header="Jitter ms" Binding="{Binding JitterMs}" Width="100" IsReadOnly="True" />
        <DataGridTextColumn Header="Loss" Binding="{Binding PacketLoss}" Width="100" IsReadOnly="True" />
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>
</Window>
